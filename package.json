{
	"name": "go-fibe-app",
	"version": "0.1.0",
	"private": true,
	"type": "module",
	"scripts": {
		"dev": "vite --host 0.0.0.0 --port 5173 --strictPort",
		"build": "tsc -b --noEmit && vite build",
		"lint": "biome check package.json tsconfig.json vite.config.ts src",
		"format": "biome format --write package.json tsconfig.json vite.config.ts src",
		"typecheck": "tsc -b --noEmit",
		"preview": "vite preview --host 0.0.0.0"
	},
	"dependencies": {
		"@tailwindcss/vite": "4.2.4",
		"@tanstack/react-query": "5.62.8",
		"@vitejs/plugin-react": "5.0.0",
		"lucide-react": "0.468.0",
		"react": "19.0.0",
		"react-dom": "19.0.0",
		"vite": "6.4.2"
	},
	"devDependencies": {
		"@biomejs/biome": "2.3.8",
		"@types/react": "19.0.0",
		"@types/react-dom": "19.0.0",
		"typescript": "5.9.3"
	}
}
